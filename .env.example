APP_NAME=Voice Assistant Studio
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

# Optional LLM provider settings.
# If these are omitted, the assistant falls back to a built-in local response engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
